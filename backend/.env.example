# --- Backups automaticos de base de datos ---
# BACKUP_ENABLED=true       (false para desactivar)
# BACKUP_HORA=3             (hora del backup diario, default 3:30 AM)
# BACKUP_RETENER=14         (cuantas copias conservar)

# --- Reporte de errores a GitHub (opcional) ---
# Token de GitHub para que el boton "Errores" del superadmin suba el reporte
# automaticamente. Usar un token fine-grained con permiso de "Contents: write"
# SOLO sobre este repo. Si no se configura, el boton "Subir a GitHub" avisa y
# se puede usar "Descargar" igual.
# GITHUB_TOKEN=
# GITHUB_REPO=alaninn/gestionq24
# GITHUB_REPORTES_BRANCH=reportes-errores
